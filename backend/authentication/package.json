{
  "name": "authentication-service",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --config jest.config.ts",
    "test:unit": "jest --config jest.config.ts --testPathPattern='/__tests__/unit/'",
    "test:integration": "jest --config jest.integration.config.ts --forceExit",
    "test:coverage": "jest --config jest.config.ts --coverage",
    "test:all": "npm run test:unit && npm run test:integration",
    "load:smoke": "k6 run load.js --env STAGE=smoke",
    "load:run": "k6 run load.js --env STAGE=load",
    "load:stress": "k6 run load.js --env STAGE=stress",
    "load:soak": "k6 run load.js --env STAGE=soak"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.56.0",
    "@opentelemetry/core": "^1.30.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/instrumentation-winston": "^0.44.0",
    "@opentelemetry/propagator-b3": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "amqplib": "^0.10.4",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.1",
    "express-async-handler": "^1.2.0",
    "generate-password": "^1.7.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.4.3",
    "morgan": "^1.10.0",
    "nanoid": "^3.3.8",
    "prom-client": "^15.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.1",
    "@types/generate-password": "^1.5.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.9.3",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.4.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
