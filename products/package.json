{
  "name": "marketplace-products",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev src/server.ts",
    "build": "tsc",
    "data:import": "ts-node-dev src/seeder.ts",
    "test": "jest --config jest.config.ts",
    "test:unit": "jest --config jest.config.ts --testPathPattern='/__tests__/unit/'",
    "test:integration": "jest --config jest.integration.config.ts --forceExit",
    "test:coverage": "jest --config jest.config.ts --coverage",
    "test:all": "npm run test:unit && npm run test:integration",
    "load:smoke": "k6 run product-load.js --env STAGE=smoke",
    "load:run": "k6 run product-load.js --env STAGE=load",
    "load:stress": "k6 run product-load.js --env STAGE=stress",
    "load:soak": "k6 run product-load.js --env STAGE=soak"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.17.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.67.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/propagator-b3": "^2.6.1",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.2",
    "bottleneck": "^2.19.5",
    "cloudinary": "^2.7.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-async-handler": "^1.2.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "moment": "^2.30.1",
    "mongoose": "^7.4.3",
    "morgan": "^1.10.0",
    "prom-client": "^15.1.3",
    "sanitize-html": "^2.17.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0-beta.3",
    "@jest/types": "^29.6.3",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.1",
    "@types/helmet": "^4.0.0",
    "@types/ioredis-mock": "^8.2.7",
    "@types/jest": "^29.5.14",
    "@types/joi": "^17.2.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/kafkajs": "^1.9.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.9.3",
    "@types/sanitize-html": "^2.16.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@types/winston": "^2.4.4",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
